{
  "name": "fc-opc-ibot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/*live*.test.ts' --exclude '**/*.live.test.ts'",
    "test:unit": "vitest run --exclude '**/*live*.test.ts' --exclude '**/*.live.test.ts'",
    "test:security": "vitest run tests/security shared/project-memory/grant-fs shared/project-memory/safe-git --exclude '**/*live*'",
    "test:live": "vitest run '**/*live*.test.ts' '**/*.live.test.ts'",
    "test:integration": "vitest run tests/integration --exclude '**/*live*'",
    "test:e2e": "playwright test",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:prepare": "npm run build && node scripts/prepare-desktop-bundle.mjs",
    "desktop:ensure-electron": "node scripts/ensure-electron-zip.mjs",
    "desktop:install-env": "node scripts/install-desktop-env.mjs",
    "desktop:package": "npm run desktop:prepare && node scripts/ensure-electron-zip.mjs && node scripts/package-desktop.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@parcel/watcher": "2.5.6",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tanstack/react-query": "^5.59.0",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
